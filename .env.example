# Local Kafka-compatible streaming
KAFKA_BOOTSTRAP_SERVERS=localhost:19092
KAFKA_TOPIC=transaction-events
KAFKA_DLQ_TOPIC=transaction-events-dlq
KAFKA_RISK_ALERT_TOPIC=streaming-risk-alerts
STREAM_EVENT_COUNT=100
STREAM_EVENT_RATE=20
STREAM_RANDOM_SEED=202612
STREAM_INVALID_EVERY=20
STREAM_DUPLICATE_EVERY=25
STREAM_LATE_EVERY=30
STREAM_PUBLISH_DLQ=true
STREAM_PUBLISH_RISK_ALERTS=true
STREAM_RISK_ALERT_AMOUNT=1000

# Optional cloud-enabled mode
GCP_PROJECT_ID=risk-data-platform-npg-2026
GCP_LOCATION=us-central1
DBT_DATASET=risk_analytics
AIRFLOW_PROJECT_PYTHON=.venv-v12/bin/python
# Mount credentials at runtime; never copy the JSON file into an image.
GOOGLE_APPLICATION_CREDENTIALS=/credentials/application_default_credentials.json

# Opt-in GCP Pub/Sub/Dataflow streaming demo. No live command runs by default.
GCP_STREAMING_REGION=us-central1
GCP_STREAMING_TOPIC=transaction-events
GCP_STREAMING_SUBSCRIPTION=transaction-events-dataflow-sub
GCP_STREAMING_DEMO_EVENT_COUNT=1000
GCP_STREAMING_EVENT_RATE=5
GCP_STREAMING_RANDOM_SEED=202614
GCP_STREAMING_MAX_DEMO_MINUTES=15
GCP_STREAMING_NUM_WORKERS=1
GCP_STREAMING_MAX_WORKERS=1
GCP_STREAMING_MACHINE_TYPE=n1-standard-1
GCP_STREAMING_SERVICE_ACCOUNT=
# Must be explicitly set to true before any live producer or Dataflow demo command.
ACKNOWLEDGE_GCP_COST_RISK=false
# Optional Terraform budget; never hardcode a billing account in source control.
GCP_BILLING_ACCOUNT_ID=

# Optional alerts
ALERT_MIN_SEVERITY=WARNING
SLACK_WEBHOOK_URL=

# Local monitoring UI credentials. Change outside a disposable local demo.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
